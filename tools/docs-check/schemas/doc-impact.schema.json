{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "goalrail/docs/doc-impact.schema.json",
  "title": "Goalrail DocImpact v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "change_kind",
    "touched_surfaces",
    "requires_research",
    "research_refs",
    "decision_refs",
    "implementation_status_changed",
    "claim_risk",
    "migration_only",
    "semantic_rewrite",
    "notes"
  ],
  "properties": {
    "change_kind": {
      "type": "string",
      "enum": [
        "docs-only",
        "research",
        "architecture",
        "public-narrative",
        "brand",
        "ops",
        "metadata-migration"
      ]
    },
    "touched_surfaces": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "requires_research": {"type": "boolean"},
    "research_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "decision_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "implementation_status_changed": {"type": "boolean"},
    "claim_risk": {
      "type": "string",
      "enum": ["none", "low", "medium", "high"]
    },
    "migration_only": {"type": "boolean"},
    "semantic_rewrite": {"type": "boolean"},
    "notes": {"type": "string"}
  }
}
