{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "goalrail/docs/docs-check-report.schema.json",
  "title": "Goalrail Docs Check Report v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "mode",
    "root",
    "summary",
    "findings",
    "checked_files",
    "fixture_results"
  ],
  "properties": {
    "schema_version": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "minLength": 1},
    "mode": {"type": "string", "minLength": 1},
    "root": {"type": "string", "minLength": 1},
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files_checked",
        "hard_count",
        "warning_count",
        "info_count",
        "fixture_count",
        "fixture_fail_count"
      ],
      "properties": {
        "files_checked": {"type": "integer", "minimum": 0},
        "hard_count": {"type": "integer", "minimum": 0},
        "warning_count": {"type": "integer", "minimum": 0},
        "info_count": {"type": "integer", "minimum": 0},
        "fixture_count": {"type": "integer", "minimum": 0},
        "fixture_fail_count": {"type": "integer", "minimum": 0}
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "severity",
          "check",
          "path",
          "line",
          "message",
          "rule",
          "expected",
          "actual",
          "context"
        ],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "severity": {
            "type": "string",
            "enum": ["info", "warning", "hard"]
          },
          "check": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "line": {"type": "integer", "minimum": 1},
          "message": {"type": "string", "minLength": 1},
          "rule": {"type": "string", "minLength": 1},
          "expected": {},
          "actual": {},
          "context": {"type": "object"}
        }
      }
    },
    "checked_files": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "fixture_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "case", "passed", "expected_path", "actual", "expected"],
        "properties": {
          "category": {"type": "string", "minLength": 1},
          "case": {"type": "string", "minLength": 1},
          "passed": {"type": "boolean"},
          "expected_path": {"type": "string", "minLength": 1},
          "actual": {"type": "object"},
          "expected": {"type": "object"}
        }
      }
    }
  }
}
